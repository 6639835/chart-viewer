{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for Chart Viewer.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://github.com/6639835/chart-viewer*"
        }
      ]
    },
    "process:allow-restart",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install"
  ]
}
